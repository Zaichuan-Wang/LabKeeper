# ── 认证 ──
# 签名密钥，部署前务必修改，可用 openssl rand -hex 32 生成
LAB_POSITION_API_SECRET=change-this-secret-before-shared-deployment
# 登录令牌有效期（秒），默认 8 小时
LAB_POSITION_TOKEN_TTL_SECONDS=28800

# ── 业务 ──
# 即将到期提醒窗口（天）
EXPIRATION_REMIND_DAYS=30

# ── 网络 ──
# CORS 允许的源，多个用逗号分隔；留空则允许所有（仅本地开发）
# 示例：http://192.168.1.100:5173,https://lab.example.com
LAB_POSITION_CORS_ORIGINS=

# ── 路径 ──
# 下拉选项配置文件（相对路径或绝对路径）
# LAB_POSITION_OPTIONS_CONFIG=config/dropdown_options.json
# 备份策略配置文件
# LAB_POSITION_BACKUP_SETTINGS=config/backup_settings.json
