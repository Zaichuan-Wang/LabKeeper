# ── 运行模式 ──
# 正式部署使用 production；本机测试可改为 development 或 test
LABKEEPER_ENV=production
# 正式部署必须关闭；本机测试需要快捷登录和载入 Demo 数据库时设为 1
LABKEEPER_ENABLE_DEV_TOOLS=0

# ── 认证 ──
# 签名密钥，部署前务必修改，可用 openssl rand -hex 32 生成
LABKEEPER_API_SECRET=change-this-secret-before-shared-deployment
# 登录令牌有效期（秒），默认 8 小时
LABKEEPER_TOKEN_TTL_SECONDS=28800
# 首次初始化正式库时创建的管理员；生产环境必须设置密码
LABKEEPER_INITIAL_ADMIN_USERNAME=admin
LABKEEPER_INITIAL_ADMIN_PASSWORD=change-this-admin-password
LABKEEPER_INITIAL_ADMIN_DISPLAY_NAME=管理员

# ── 本机测试工具 ──
# 仅 LABKEEPER_ENABLE_DEV_TOOLS=1 时生效
LABKEEPER_DEV_ADMIN_USERNAME=admin
LABKEEPER_DEV_ADMIN_PASSWORD=admin123

# ── 业务 ──
# 即将到期提醒窗口（天）
LABKEEPER_EXPIRATION_REMIND_DAYS=30

# ── 网络 ──
# CORS 允许的源，多个用逗号分隔；正式部署请填写实际域名
# 示例：http://192.168.1.100:5173,https://lab.example.com
LABKEEPER_CORS_ORIGINS=http://127.0.0.1:5173

# ── 路径 ──
# 下拉选项配置文件（相对路径或绝对路径）
# LABKEEPER_OPTIONS_CONFIG=config/dropdown_options.json
# 备份策略配置文件
# LABKEEPER_BACKUP_SETTINGS=config/backup_settings.json
